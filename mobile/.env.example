# Public Supabase credentials — safe to ship to the client
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL for VoxTree's Next.js API (used for voice creation, clip generation,
# and Stripe checkout). In development this is usually http://<your-LAN-ip>:3000.
EXPO_PUBLIC_API_BASE_URL=https://voxtree.app
